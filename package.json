{
  "name": "@secpal/android",
  "version": "0.0.1",
  "description": "SecPal Android app foundation based on React, TypeScript, Vite, and Capacitor",
  "private": true,
  "type": "module",
  "author": "SecPal",
  "license": "AGPL-3.0-or-later",
  "repository": {
    "type": "git",
    "url": "https://github.com/SecPal/android.git"
  },
  "homepage": "https://github.com/SecPal/android#readme",
  "bugs": {
    "url": "https://github.com/SecPal/android/issues"
  },
  "keywords": [
    "secpal",
    "android",
    "capacitor",
    "react",
    "typescript",
    "dpc",
    "android-enterprise"
  ],
  "scripts": {
    "build": "bash ./scripts/build-frontend-web.sh",
    "frontend:build": "bash ./scripts/build-frontend-web.sh",
    "lint": "eslint . --ext ts,tsx --max-warnings 0",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:run": "vitest run --bail=1",
    "test:coverage": "vitest run --coverage",
    "format": "prettier --write --cache '**/*.{md,yml,yaml,json,ts,tsx,js,jsx,css,scss,html}'",
    "format:check": "prettier --check '**/*.{md,yml,yaml,json,ts,tsx,js,jsx,css,scss,html}'",
    "cap:sync": "npm run frontend:build && npx cap sync android",
    "cap:copy": "npm run frontend:build && npx cap copy android",
    "cap:add:android": "npx cap add android",
    "cap:open:android": "npx cap open android"
  },
  "dependencies": {
    "@capacitor/android": "^7.4.3",
    "@capacitor/core": "^7.4.3",
    "react": "^19.2.3",
    "react-dom": "^19.2.3"
  },
  "devDependencies": {
    "@capacitor/cli": "^7.4.3",
    "@eslint/js": "^9.37.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^24.6.1",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@typescript-eslint/eslint-plugin": "^8.46.1",
    "@typescript-eslint/parser": "^8.46.1",
    "@vitejs/plugin-react": "^5.0.4",
    "eslint": "^9.37.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.23",
    "globals": "^16.4.0",
    "jsdom": "^27.0.0",
    "prettier": "^3.6.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.46.1",
    "vite": "^7.1.7",
    "vitest": "^3.2.4",
    "@vitest/coverage-v8": "^3.2.4"
  },
  "engines": {
    "node": ">=22.0.0",
    "npm": ">=10.0.0"
  }
}
